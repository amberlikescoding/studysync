# ─── ANTHROPIC (CLAUDE) ───────────────────────────────────────────────────────
# Get from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ─── APP ──────────────────────────────────────────────────────────────────────
PORT=3001

# ─── WPPCONNECT ───────────────────────────────────────────────────────────────
# Name for the local WhatsApp session (used as the token folder name).
# You can use anything — it's just a label for the saved session file.
# After the first QR scan this session is saved and reused on restarts.
WPP_SESSION_NAME=studysync-demo

# ─── DATABASE ─────────────────────────────────────────────────────────────────
# SQLite file — relative to backend/ directory. Created automatically.
DB_PATH=./studysync.db
